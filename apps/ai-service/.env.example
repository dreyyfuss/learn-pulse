KAFKA_BOOTSTRAP_SERVERS=kafka:9092
KAFKA_GROUP_ID=ai-service-indexer
KAFKA_TOPIC_COURSE_PUBLISHED=course.published

GROQ_API_KEY=your-key-here
GROQ_LLM_MODEL=llama-3.3-70b-versatile

# Embedding model (local sentence-transformers)
EMBEDDING_MODEL=sentence-transformers/all-MiniLM-L6-v2
CHUNK_SIZE=400
CHUNK_OVERLAP=50

CHROMA_HOST=chromadb
CHROMA_PORT=8000
CHROMA_COLLECTION=learnpulse_courses

REDIS_URL=redis://redis:6379

# Shared secret used by ai-service when calling course-service internal endpoints.
# Must match SERVICE_AUTH_SECRET in course-service.
SERVICE_AUTH_SECRET=change-me-in-production
COURSE_SERVICE_URL=http://course-service:8080
