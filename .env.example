# ── Deployment ────────────────────────────────────────────────
# Public base URL for MinIO S3 (used in presigned URLs returned to the browser)
# Set to your VPS public IP or domain, port 9010
APP_S3_PUBLIC_ENDPOINT=http://YOUR_VPS_IP:9010

# Strong random secret shared between course-service and ai-service
# Generate with: openssl rand -hex 32
SERVICE_AUTH_SECRET=change-me

# ── AI providers (provide at least one) ───────────────────────
CEREBRAS_API_KEY=
CEREBRAS_MODEL=llama-3.1-8b
GROQ_API_KEY=

# ── Email (Mailgun) ───────────────────────────────────────────
# Sign up at https://mailgun.com — free sandbox tier works for dev
MAILGUN_API_KEY=
MAILGUN_DOMAIN=sandbox.mailgun.org
MAILGUN_FROM=noreply@learnpulse.dev