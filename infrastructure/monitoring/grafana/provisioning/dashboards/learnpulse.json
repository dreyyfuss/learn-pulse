{
  "title": "LearnPulse Overview",
  "uid": "learnpulse-overview",
  "version": 1,
  "schemaVersion": 39,
  "refresh": "30s",
  "time": { "from": "now-1h", "to": "now" },
  "templating": {
    "list": [
      {
        "name": "service",
        "type": "custom",
        "label": "Service",
        "current": { "value": "course-service", "text": "course-service" },
        "options": [
          { "value": "course-service", "text": "course-service", "selected": true },
          { "value": "user-service",   "text": "user-service",   "selected": false },
          { "value": "cert-service",   "text": "cert-service",   "selected": false }
        ],
        "multi": false,
        "includeAll": true,
        "allValue": "course-service|user-service|cert-service"
      }
    ]
  },
  "panels": [
    {
      "id": 1,
      "type": "row",
      "title": "JVM",
      "gridPos": { "x": 0, "y": 0, "w": 24, "h": 1 },
      "collapsed": false
    },
    {
      "id": 2,
      "title": "Heap Memory Used",
      "type": "timeseries",
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "gridPos": { "x": 0, "y": 1, "w": 6, "h": 8 },
      "fieldConfig": {
        "defaults": { "unit": "bytes", "color": { "mode": "palette-classic" } }
      },
      "targets": [
        {
          "expr": "jvm_memory_used_bytes{job=~\"$service\", area=\"heap\"}",
          "legendFormat": "{{job}} {{id}}"
        }
      ]
    },
    {
      "id": 3,
      "title": "GC Pause Rate (ops/s)",
      "type": "timeseries",
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "gridPos": { "x": 6, "y": 1, "w": 6, "h": 8 },
      "targets": [
        {
          "expr": "rate(jvm_gc_pause_seconds_count{job=~\"$service\"}[1m])",
          "legendFormat": "{{job}} {{action}}"
        }
      ]
    },
    {
      "id": 4,
      "title": "Live Threads",
      "type": "timeseries",
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "gridPos": { "x": 12, "y": 1, "w": 6, "h": 8 },
      "targets": [
        {
          "expr": "jvm_threads_live_threads{job=~\"$service\"}",
          "legendFormat": "{{job}}"
        }
      ]
    },
    {
      "id": 5,
      "title": "CPU Usage",
      "type": "timeseries",
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "gridPos": { "x": 18, "y": 1, "w": 6, "h": 8 },
      "fieldConfig": {
        "defaults": { "unit": "percentunit", "min": 0, "max": 1 }
      },
      "targets": [
        {
          "expr": "process_cpu_usage{job=~\"$service\"}",
          "legendFormat": "{{job}}"
        }
      ]
    },
    {
      "id": 10,
      "type": "row",
      "title": "HTTP",
      "gridPos": { "x": 0, "y": 9, "w": 24, "h": 1 },
      "collapsed": false
    },
    {
      "id": 11,
      "title": "Request Rate (req/s)",
      "type": "timeseries",
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "gridPos": { "x": 0, "y": 10, "w": 8, "h": 8 },
      "targets": [
        {
          "expr": "sum(rate(http_server_requests_seconds_count{job=~\"$service\"}[1m])) by (job)",
          "legendFormat": "{{job}}"
        }
      ]
    },
    {
      "id": 12,
      "title": "p99 Response Time",
      "type": "timeseries",
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "gridPos": { "x": 8, "y": 10, "w": 8, "h": 8 },
      "fieldConfig": {
        "defaults": { "unit": "s" }
      },
      "targets": [
        {
          "expr": "histogram_quantile(0.99, sum(rate(http_server_requests_seconds_bucket{job=~\"$service\"}[1m])) by (job, le))",
          "legendFormat": "{{job}}"
        }
      ]
    },
    {
      "id": 13,
      "title": "5xx Error Rate",
      "type": "timeseries",
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "gridPos": { "x": 16, "y": 10, "w": 8, "h": 8 },
      "targets": [
        {
          "expr": "sum(rate(http_server_requests_seconds_count{job=~\"$service\", status=~\"5..\"}[1m])) by (job)",
          "legendFormat": "{{job}} 5xx"
        }
      ]
    },
    {
      "id": 20,
      "type": "row",
      "title": "AI Service",
      "gridPos": { "x": 0, "y": 18, "w": 24, "h": 1 },
      "collapsed": false
    },
    {
      "id": 21,
      "title": "AI Request Rate (req/s)",
      "type": "timeseries",
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "gridPos": { "x": 0, "y": 19, "w": 12, "h": 8 },
      "targets": [
        {
          "expr": "sum(rate(http_requests_total{job=\"ai-service\"}[1m]))",
          "legendFormat": "ai-service"
        }
      ]
    },
    {
      "id": 22,
      "title": "AI p99 Latency",
      "type": "timeseries",
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "gridPos": { "x": 12, "y": 19, "w": 12, "h": 8 },
      "fieldConfig": {
        "defaults": { "unit": "s" }
      },
      "targets": [
        {
          "expr": "histogram_quantile(0.99, sum(rate(http_request_duration_seconds_bucket{job=\"ai-service\"}[1m])) by (le))",
          "legendFormat": "p99"
        }
      ]
    }
  ]
}
